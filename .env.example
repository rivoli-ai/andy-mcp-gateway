# Copy to `.env` and adjust. Compose reads this file for ${...} interpolation (see docker-compose.yml).
# For local `dotnet run`, align values with `backend/src/McpGateway/appsettings.Development.json` if you use that profile.

# ── Postgres (container + ConnectionStrings via compose) ────────────────────────
# Must match the DB user/password created on FIRST volume init. If you see 28P01, either align these
# with that init or run: docker compose down -v  (deletes DB data), then set DB_* and docker compose up -d.
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mcp_gateway

POSTGRES_HOST_PORT=5434
BACKEND_HOST_PORT=8070
FRONTEND_HOST_PORT=4201

# ── API ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=dev-secret-key-min-32-characters-long-for-security
JWT_ISSUER=McpGateway
JWT_AUDIENCE=McpGateway

ASPNETCORE_ENVIRONMENT=Development

# ── Angular (browser) — must match how you open the UI (scheme, host, port) ─────
API_URL=http://localhost:4201

# ── Azure AD (optional overrides; compose defaults match appsettings.Development.json) ──
AUTH_AZURE_ENABLED=true
# AUTH_AZURE_AUTHORITY=
# AUTH_AZURE_CLIENT_ID=
# AUTH_AZURE_SPA_CLIENT_ID=
# AUTH_AZURE_TENANT_ID=
# AUTH_AZURE_SCOPES=openid profile email User.Read
